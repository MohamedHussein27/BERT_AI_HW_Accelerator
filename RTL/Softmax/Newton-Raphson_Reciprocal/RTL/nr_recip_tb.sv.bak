`timescale 1ns/1ps

module nr_recip_debug_tb;

  // ---------- params ----------
  parameter WIDTH = 32;
  parameter Q     = 26;
  parameter START_PULSE_CYCLES = 4; // hold start for this many cycles when sending input

  // ---------- DUT I/O ----------
  reg clk;
  reg rst_n;
  reg start;
  reg signed [WIDTH-1:0] a_in_q;
  wire busy;
  wire done;
  wire signed [WIDTH-1:0] y_out_q;

  // ---------- test vectors ----------
  integer NUM_TEST = 8;
  reg signed [WIDTH-1:0] tests_q [0:15];
  real tests_real [0:15];

  // ---------- internal ----------
  integer i, c;
  integer timeout_cnt;

  // ---------- instantiate DUT (change name/ports if needed) ----------
  nr_recip dut (
    .clk    (clk),
    .rst_n  (rst_n),
    .start  (start),
    .a_in_q (a_in_q),
    .busy   (busy),
    .done   (done),
    .y_out_q(y_out_q)
  );

  // ---------- clock ----------
  initial begin
    clk = 0;
    forever #5 clk = ~clk; // 100MHz
  end

  // ---------- helper: real->Q ----------
  function automatic signed [WIDTH-1:0] real_to_q;
    input real r;
    real tmp;
    begin
      tmp = r * (1 << Q);
      real_to_q = $rtoi(tmp);
    end
  endfunction

  // ---------- prepare test vectors ----------
  initial begin
    // some examples — include 1.0, 2.0, 0.5, some larger numbers
    tests_real[0] = 1.0;
    tests_real[1] = 2.0;
    tests_real[2] = 11.20603;
    tests_real[3] = 11.28593;
    tests_real[4] = 15.920101;
    tests_real[5] = 16.0;
    tests_real[6] = 0.5;
    tests_real[7] = 3.14159;

    for (i = 0; i < NUM_TEST; i = i + 1) begin
      tests_q[i] = real_to_q(tests_real[i]);
    end
  end

  // ---------- optional: load ROMs (uncomment & adjust names if DUT mem path known) ----------
  initial begin
    #1;
    // Example if your DUT memory is at dut.lut_mem: $readmemh("nr_lut.hex", dut.lut_mem);
    // $display("Loaded LUTs (if any).");
  end

  // ---------- test sequence ----------
  initial begin
    // initial values
    rst_n = 0;
    start = 0;
    a_in_q = 0;
    #20;
    rst_n = 1;
    #20;

    $display("Starting tests at time %0t", $time);

    for (i = 0; i < NUM_TEST; i = i + 1) begin
      a_in_q = tests_q[i];

      $display("\n-- Test %0d: a_real=%f a_q=%08h @ time %0t", i, tests_real[i], a_in_q, $time);

      // pulse start for multiple cycles to be robust to handshake style
      for (c = 0; c < START_PULSE_CYCLES; c = c + 1) begin
        @(posedge clk);
        start = 1;
      end
      @(posedge clk);
      start = 0;

      // wait for busy to go high (optional, with timeout)
      timeout_cnt = 0;
      while (!busy) begin
        @(posedge clk);
        timeout_cnt = timeout_cnt + 1;
        if (timeout_cnt > 50) begin
          $display(" WARNING: busy never asserted within 50 cycles after start (time=%0t). busy=%b done=%b", $time, busy, done);
          break;
        end
      end
      if (busy) $display(" busy asserted at time %0t", $time);

      // wait for done (with generous timeout)
      timeout_cnt = 0;
      while (!done) begin
        @(posedge clk);
        timeout_cnt = timeout_cnt + 1;
        if (timeout_cnt > 500) begin
          $display(" TIMEOUT waiting for done for test %0d (a_real=%f) at time %0t", i, tests_real[i], $time);
          disable wait_done;
        end
      end
      wait_done: ;

      // sample output
      $display(" done=%b at time %0t, y_out_q=%08h (float=%f), busy=%b", done, $time, y_out_q, $itor($signed(y_out_q))/(1<<Q), busy);

      // small delay before next test
      repeat (2) @(posedge clk);
    end

    $display("\nAll tests finished at time %0t", $time);
    $finish;
  end

endmodule
